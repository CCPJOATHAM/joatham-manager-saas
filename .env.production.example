# JOATHAM Manager - exemple de configuration production
# Copier ce fichier en .env sur le VPS puis remplacer toutes les valeurs CHANGE_ME.

DJANGO_DEBUG=False
DJANGO_SECRET_KEY=CHANGE_ME_GENERATE_A_LONG_RANDOM_SECRET

# Domaine recommande pour l'application SaaS.
DJANGO_ALLOWED_HOSTS=app.joatham.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://app.joatham.com

# Base de donnees PostgreSQL.
DJANGO_DB_ENGINE=django.db.backends.postgresql
DJANGO_DB_NAME=joatham_prod
DJANGO_DB_USER=joatham_user
DJANGO_DB_PASSWORD=CHANGE_ME_DATABASE_PASSWORD
DJANGO_DB_HOST=127.0.0.1
DJANGO_DB_PORT=5432
DJANGO_DB_CONN_MAX_AGE=60

# Fichiers statiques et medias.
DJANGO_STATIC_URL=/static/
DJANGO_STATIC_ROOT=/home/joatham/apps/joatham_pro/staticfiles
DJANGO_MEDIA_URL=/media/
DJANGO_MEDIA_ROOT=/home/joatham/apps/joatham_pro/media

# Email SMTP Hostinger.
DJANGO_EMAIL_HOST=smtp.hostinger.com
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_HOST_USER=no-reply@joatham.com
DJANGO_EMAIL_HOST_PASSWORD=CHANGE_ME_HOSTINGER_EMAIL_PASSWORD
DJANGO_EMAIL_USE_TLS=True
DJANGO_EMAIL_USE_SSL=False
DJANGO_EMAIL_TIMEOUT=30
DJANGO_DEFAULT_FROM_EMAIL=JOATHAM Manager <no-reply@joatham.com>

# Authentification et securite.
DJANGO_PASSWORD_MIN_LENGTH=10
DJANGO_PASSWORD_RESET_TIMEOUT=3600
DJANGO_PASSWORD_RESET_REQUEST_COOLDOWN=60
DJANGO_EMAIL_VERIFICATION_TIMEOUT=3600

# HTTPS. A activer apres installation du certificat SSL sur Nginx.
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True
DJANGO_USE_X_FORWARDED_PROTO=True
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
DJANGO_SECURE_HSTS_PRELOAD=False

# Parametres applicatifs.
DJANGO_LANGUAGE_CODE=fr-fr
DJANGO_TIME_ZONE=Africa/Kinshasa
JOATHAM_PDF_ENGINE=xhtml2pdf
JOATHAM_BILLING_PAGE_SIZE=20
JOATHAM_FACTURE_NUMBER_FORMAT=standard
DJANGO_LOG_LEVEL=INFO

# Stripe sera configure plus tard.
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=usd
